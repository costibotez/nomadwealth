# =========================================================================
#  NomadWealth — environment variables
#  Copy to `.env.local` for local dev. On Vercel, the "Deploy" button + Neon
#  integration inject DATABASE_URL for you; add the others in Project Settings.
#  NEVER commit real values to git.
# =========================================================================

# --- Database (Neon serverless Postgres) — REQUIRED ----------------------
# Provisioned automatically by the Vercel + Neon integration on deploy. For
# local dev, copy the *pooled* connection string from the Neon console.
DATABASE_URL="postgresql://user:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# --- Auth — REQUIRED -----------------------------------------------------
# Secret used to sign the owner session cookie (HMAC-SHA256).
# Generate one with:  openssl rand -base64 48
SESSION_SECRET="generate-a-long-random-string"

# Optional fallback password. The setup wizard stores a hashed owner password
# in your database, which takes precedence at login. DASHBOARD_PASSWORD is only
# used when no owner row exists (e.g. the legacy CLI/advanced install path).
DASHBOARD_PASSWORD=""

# --- License revocation --------------------------------------------------
# On activation the install POSTs ONLY the opaque key to a revocation endpoint
# and downgrades to trial if it returns { revoked: true } — never any financial
# data, and it fails OPEN (a network blip never bricks an install). The vendor
# endpoint is BAKED ON by default (src/lib/license.ts), so you normally set
# NOTHING here.
#   - Override the URL:  set LICENSE_API_URL to your own endpoint.
#   - Turn it OFF:       set LICENSE_API_URL="" (empty string) on that install.
# LICENSE_API_URL="https://admin.nomadwealth.app/api/license/check"

# Where the OPT-IN activation ping goes (default off; toggled per-install on the
# License page). Sends only a hashed key + tier — never financial data. Override
# the baked-in vendor admin URL here if needed.
# NW_ACTIVATION_PING_URL="https://admin.nomadwealth.app/api/activations"

# --- Marketing / SEO (optional) ------------------------------------------
# Absolute site URL used for canonical links, OG images, sitemap and robots.
# NOTE: the apex 308-redirects to www, so use the www host here.
NEXT_PUBLIC_SITE_URL="https://www.nomadwealth.app"
# PUBLIC deploy-template repo the "Deploy to Vercel" button clones (DEPLOY_URL
# in src/components/marketing/content.ts is built from this). It MUST be a public
# repo or the buyer's one-click deploy fails. Keep it in sync with the private
# source via scripts/sync-public.sh.
NEXT_PUBLIC_REPO_URL="https://github.com/costibotez/nomadwealth"

# Google Analytics 4 — set ONLY on the vendor's marketing deployment. When set,
# the GA4 gtag.js script loads on the public marketing pages (never the
# dashboard, never buyer installs). Buyers leave this unset. NOTE: GA4 sets
# cookies and shares data with Google — EU visitors need a consent gate.
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- Feedback & Support hub (/feedback) — vendor marketing only ----------
# Set ONLY on the vendor's marketing deployment; buyers leave it unset (the form
# falls back to a mailto: link, so nothing breaks on self-host installs). The
# form never collects financial data — just intent, an optional email, and free
# text. All three intents (support / feature / feedback) submit a message.
#
# The admin app's public feedback endpoint the client POSTs to directly.
# NEXT_PUBLIC_FEEDBACK_ENDPOINT="https://admin.nomadwealth.app/api/feedback"

# --- Early access waitlist (pre-launch) — vendor marketing only ----------
# Set ONLY on the vendor's marketing deployment; buyers leave this unset. The
# homepage "Get early access" form POSTs only `{ email }` from the browser
# directly to this endpoint (a hosted form service, or the separate admin
# app's waitlist endpoint) — no vendor backend, no financial data, and the
# waitlist never lands in this product's Neon DB. Left unset, the form falls
# back to a mailto: link so buyer self-host installs never break.
# NEXT_PUBLIC_WAITLIST_ENDPOINT="https://formspree.io/f/xxxxxxx"

# --- Pricing campaign (promo pricing) — vendor marketing only -------------
# Set ONLY on the vendor's marketing deployment; buyers MUST leave this unset
# (when unset the site never contacts the vendor admin — no banner, normal
# prices). Server-side URL of the admin app's public campaign endpoint. When a
# campaign is live, the site shows a promo banner + discounted prices and
# prefills the Stripe promo code at checkout. Carries no financial data.
# CAMPAIGN_ENDPOINT="https://admin.nomadwealth.app/api/campaign"

# --- Pricing (Stripe Payment Links) --------------------------------------
# Override the landing-page pricing CTAs. Defaults are the live links baked
# into src/components/marketing/content.ts. Payment only collects money —
# license keys are signed offline and emailed after purchase (see README).
# NEXT_PUBLIC_STRIPE_SELFHOST_URL="https://buy.stripe.com/..."
# NEXT_PUBLIC_STRIPE_RENEW_URL="https://buy.stripe.com/..."
# NEXT_PUBLIC_STRIPE_HOSTED_URL="https://buy.stripe.com/..."

# --- FX ------------------------------------------------------------------
# The FX provider (Frankfurter) is keyless — nothing required.
# FX_PROVIDER_URL="https://api.frankfurter.app/latest"

# --- Live prices (optional) ---------------------------------------------
# Bring your OWN CoinMarketCap key for live crypto prices. Stocks use keyless
# Yahoo Finance. Nothing routes through the vendor.
CMC_API_KEY=""

# Secret for the daily price-refresh cron (Vercel Cron sends it as a Bearer token).
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# =========================================================================
#  VENDOR ONLY — do NOT set these on a buyer self-host install.
#  These power the Stripe → sign-license-key → email flow on the vendor's
#  own deployment (e.g. nomadwealth.app). Without them, /api/webhooks/stripe
#  is inert. The signing key NEVER touches buyer data.
# =========================================================================
# Ed25519 private key (pkcs8, base64url) that signs license keys. The matching
# public key is embedded in src/lib/license.ts. Generate a pair once and keep
# this secret (see scripts/sign-license.ts). Also written to
# .nomadwealth-license-key.local by the generator (gitignored).
# NW_LICENSE_PRIVATE_KEY=""
# Stripe webhook signing secret (Developers → Webhooks → your endpoint).
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Resend API key + verified from-address for emailing license keys.
# RESEND_API_KEY="re_..."
# LICENSE_FROM_EMAIL="NomadWealth <keys@nomadwealth.app>"
# Optional: from-address for price-alert emails (falls back to LICENSE_FROM_EMAIL).
# Needs RESEND_API_KEY set. Web Push alerts are keyless — no config required.
# ALERT_FROM_EMAIL="NomadWealth Alerts <alerts@nomadwealth.app>"
